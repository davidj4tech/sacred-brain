[Unit]
Description=Memory Governor (Agno + Mem0) service
After=network-online.target litellm-compose.service hippocampus.service
Wants=network-online.target

[Service]
Type=simple
User=sacred
Group=sacred
EnvironmentFile=/etc/sacred-brain/memory-governor.env
ExecStart=/usr/local/bin/memory-governor
Restart=always
RestartSec=3

# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/var/lib/sacred-brain
ReadOnlyPaths=/opt/pipx /etc/sacred-brain
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictSUIDSGID=true

[Install]
WantedBy=multi-user.target
