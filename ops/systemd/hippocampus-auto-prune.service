[Unit]
Description=Prune auto memories (low-salience) from Hippocampus
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/opt/sacred-brain
User=sacred
Group=sacred
EnvironmentFile=/etc/sacred-brain/hippocampus.env
Environment=HIPPOCAMPUS_SQLITE_PATH=/var/lib/sacred-brain/hippocampus/hippocampus_memories.sqlite
ExecStart=/opt/pipx/venvs/sacred-brain-hippocampus/bin/python scripts/prune_auto_memories.py

# Hardening (lighter for oneshot)
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/var/lib/sacred-brain
ReadOnlyPaths=/opt/sacred-brain /opt/pipx /etc/sacred-brain
ProtectKernelTunables=true
ProtectKernelModules=true

[Install]
WantedBy=multi-user.target
