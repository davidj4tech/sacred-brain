[Unit]
Description=Baibot TTS/STT (docker compose)
Requires=docker.service
After=docker.service network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/sacred-brain/ops/compose/baibot
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=60
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
