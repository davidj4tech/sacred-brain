#!/usr/bin/env bash
# sacred-mcp-stdio — launcher for the Sacred Brain MCP server (stdio transport).
#
# Sources ~/.config/hippocampus.env if present so HIPPOCAMPUS_URL / _API_KEY /
# _USER_ID flow through to the server without per-client duplication.
#
# Usage: add to your MCP client as:
#   claude mcp add sacred-brain /home/<user>/.local/bin/sacred-mcp-stdio
# Or in Claude Desktop claude_desktop_config.json:
#   "sacred-brain": { "command": "/home/<user>/.local/bin/sacred-mcp-stdio" }
set -euo pipefail

for f in "$HOME/.config/hippocampus.env" "$HOME/.config/sacred-brain.env"; do
  if [[ -r "$f" ]]; then set -a; . "$f"; set +a; break; fi
done

# Writes from coding agents land in a dedicated bucket by default so they
# don't pollute the chat-persona scopes (sam/mel). Override per-host by
# exporting SACRED_MCP_DEFAULT_WRITE_USER_ID before invoking the launcher.
: "${SACRED_MCP_DEFAULT_WRITE_USER_ID:=coding_agent}"
export SACRED_MCP_DEFAULT_WRITE_USER_ID

# Prefer an in-tree checkout if present; fall back to importable install.
REPO="${SACRED_BRAIN_ROOT:-/opt/sacred-brain}"
if [[ -d "$REPO/services/sacred_mcp" ]]; then
  cd "$REPO"
fi

exec python3 -m services.sacred_mcp.stdio
